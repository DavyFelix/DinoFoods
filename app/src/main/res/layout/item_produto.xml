<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/roxo_claro">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Imagem -->
        <ImageView
            android:id="@+id/imgProduto"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:background="@color/roxo_claro"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Nome -->
        <TextView
            android:id="@+id/tvNomeProduto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hambúrguer Especial"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/roxo_escuro"
            app:layout_constraintStart_toEndOf="@id/imgProduto"
            app:layout_constraintTop_toTopOf="@id/imgProduto"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="16dp"/>

        <!-- Descrição -->
        <TextView
            android:id="@+id/tvDescricao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Carne 180g, cheddar, pão brioche"
            android:textSize="14sp"
            android:textColor="#666666"
            app:layout_constraintStart_toStartOf="@id/tvNomeProduto"
            app:layout_constraintTop_toBottomOf="@id/tvNomeProduto"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="6dp"/>

        <!-- Preço -->
        <TextView
            android:id="@+id/tvPreco"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R$ 29,90"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/roxo_primario"
            app:layout_constraintStart_toStartOf="@id/tvNomeProduto"
            app:layout_constraintBottom_toBottomOf="@id/imgProduto"
            android:layout_marginTop="8dp"/>

        <!-- Botão Adicionar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdicionar"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Adicionar"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="@color/branco"
            app:cornerRadius="20dp"
            app:backgroundTint="@color/roxo_primario"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/imgProduto"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>